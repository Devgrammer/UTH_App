---
graph TB

    classDef title fill:#ee6c4dff,stroke:#437c90ff,stroke-width:2px,color:#fefee3ff,font-weight:bold
    classDef sectionHeader fill:#1a2332,stroke:#ee6c4dff,stroke-width:1px,color:#ee6c4dff,font-weight:bold

    subgraph MAIN["🏢 BANQUET HALL MANAGEMENT SYSTEM"]
        direction TB
        H1[">>> 👤 USER & AUTHENTICATION FLOW <<<"]
        H2[">>> 📦 INVENTORY MANAGEMENT FLOW <<<"]
        H3[">>> 📊 STATUS TRACKING FLOW <<<"]
        H4[">>> 📅 BOOKING & CHECKOUT FLOW <<<"]
        H5[">>> 🔄 ITEM STATUS STATE MACHINE <<<"]
        H6[">>> 🗄️ DATABASE SCHEMA <<<"]
        H7[">>> 📈 REPORTS & ANALYTICS <<<"]
        H8[">>> 🔔 NOTIFICATIONS <<<"]
        
        class H1,H2,H3,H4,H5,H6,H7,H8 sectionHeader
        
        Start([🚀 START]) --> CheckRole{CHECK USER ROLE}
        CheckRole -->|Customer| CustomerPortal[👥 CUSTOMER DASHBOARD]
        CheckRole -->|Admin| AdminPortal[👑 ADMIN DASHBOARD]
        CheckRole -->|Staff| StaffPortal[📋 STAFF DASHBOARD]
        
        CustomerPortal --> BrowseVenues[🏛️ BROWSE VENUES]
        CustomerPortal --> MakeBooking[📅 MAKE BOOKING]
        
        AdminPortal --> InventoryMgmt[📦 INVENTORY MANAGEMENT]
        AdminPortal --> BookingMgmt[📊 BOOKING MANAGEMENT]
        AdminPortal --> Reports[📈 VIEW REPORTS]
        
        StaffPortal --> ProcessCheckout[✅ PROCESS CHECKOUT/RETURN]
        StaffPortal --> UpdateStatus[🔄 UPDATE ITEM STATUS]
        
        H1 -.-> Start
        H2 -.-> InventoryMgmt
        
        InventoryMgmt --> Action{⚡ CHOOSE ACTION}
        
        Action -->|Add New Item| AddItem[📝 FILL ITEM DETAILS]
        Action -->|View Items| ViewItems[👁️ VIEW INVENTORY LIST]
        Action -->|Update Status| UpdateItemStatus[🛠️ SELECT ITEM TO UPDATE]
        
        AddItem --> UploadImages[📸 UPLOAD IMAGES]
        UploadImages --> SetDetails[⚙️ SET DETAILS]
        SetDetails --> SaveItem[💾 SAVE TO DATABASE]
        SaveItem --> ItemSaved[✅ ITEM ADDED]
        
        ViewItems --> Filter{🔍 FILTER OPTIONS}
        Filter -->|By Category| CatFilter[📑 FILTER BY CATEGORY]
        Filter -->|By Status| StatusFilter[🏷️ FILTER BY STATUS]
        Filter -->|Search| SearchItem[🔎 SEARCH BY NAME]
        CatFilter --> DisplayGrid[🖼️ DISPLAY ITEMS GRID]
        StatusFilter --> DisplayGrid
        SearchItem --> DisplayGrid
        
        DisplayGrid --> ItemActions{🎯 ITEM ACTIONS}
        ItemActions -->|Edit| EditItem[✏️ EDIT ITEM DETAILS]
        ItemActions -->|Delete| DeleteConfirm{⚠️ CONFIRM DELETE}
        ItemActions -->|View Details| ItemDetails[🔍 VIEW FULL DETAILS]
        
        DeleteConfirm -->|Yes| DeleteItem[🗑️ SOFT DELETE ITEM]
        DeleteConfirm -->|No| DisplayGrid
        
        EditItem --> UpdateItem[🔄 UPDATE DATABASE]
        UpdateItem --> DisplayGrid
        
        H3 -.-> UpdateItemStatus
        
        UpdateItemStatus --> SelectStatus{🎛️ SELECT NEW STATUS}
        
        SelectStatus -->|Available| SetAvailable[🟢 MARK AVAILABLE]
        SelectStatus -->|Rented| SetRented[🟡 MARK RENTED]
        SelectStatus -->|Damaged| SetDamaged[🔴 LOG DAMAGE REPORT]
        SelectStatus -->|Maintenance| SetMaintenance[🟠 SCHEDULE MAINTENANCE]
        SelectStatus -->|Lost| SetLost[⚫ MARK AS LOST]
        
        SetDamaged --> CreateReport[📋 CREATE DAMAGE REPORT]
        CreateReport --> NotifyAdmin[📧 NOTIFY ADMIN]
        NotifyAdmin --> SetStatusDamaged[🔴 STATUS: DAMAGED]
        
        SetMaintenance --> ScheduleDate[📅 SELECT DATE]
        ScheduleDate --> AssignStaff[👨‍🔧 ASSIGN STAFF]
        AssignStaff --> SetStatusMaint[🟠 STATUS: MAINTENANCE]
        
        SetStatusDamaged --> LogChange[📝 LOG STATUS CHANGE]
        SetStatusMaint --> LogChange
        SetAvailable --> LogChange
        SetRented --> LogChange
        
        LogChange --> EndStatus[✅ STATUS UPDATED]
        
        H4 -.-> MakeBooking
        
        MakeBooking --> SelectVenue[🏛️ SELECT VENUE & DATE]
        SelectVenue --> CheckAvailability{📆 CHECK AVAILABILITY}
        CheckAvailability -->|Available| SelectItems[🛒 SELECT ITEMS]
        CheckAvailability -->|Not Available| SuggestAlternatives[💡 SUGGEST ALTERNATIVES]
        
        SuggestAlternatives --> CustomerChoice{🤔 CUSTOMER ACCEPTS?}
        CustomerChoice -->|Yes| SelectItems
        CustomerChoice -->|No| MakeBooking
        
        SelectItems --> CheckItemAvailability{📦 ITEMS AVAILABLE?}
        CheckItemAvailability -->|All Available| ReserveItems[🔒 RESERVE ITEMS]
        CheckItemAvailability -->|Partial| ShowPartial[📊 SHOW PARTIAL]
        
        ShowPartial --> AdjustBooking[⚖️ ADJUST QUANTITIES]
        AdjustBooking --> ReserveItems
        
        ReserveItems --> CreateTransaction[📄 CREATE TRANSACTION]
        CreateTransaction --> CalculateTotal[💰 CALCULATE TOTAL]
        CalculateTotal --> ProcessPayment[💳 PROCESS PAYMENT]
        ProcessPayment --> ConfirmBooking[✅ BOOKING CONFIRMED]
        
        ConfirmBooking --> IssueItems[🚚 ISSUE ITEMS]
        IssueItems --> EventDay[🎉 EVENT DAY]
        EventDay --> CollectItems[📦 COLLECT ITEMS]
        CollectItems --> InspectItems[🔍 INSPECT ITEMS]
        
        InspectItems -->|Good| ReturnItems[♻️ RETURN TO INVENTORY]
        InspectItems -->|Damaged| ProcessDamage[⚠️ PROCESS DAMAGE]
        
        ReturnItems --> UpdateInventory[🔄 UPDATE INVENTORY]
        ProcessDamage --> UpdateDamagedStatus[🔴 UPDATE STATUS]
        
        UpdateInventory --> CompleteBooking[🏁 BOOKING COMPLETE]
        UpdateDamagedStatus --> CompleteBooking
        
        H5 -.-> S1
        
        S1([🏁 START]) --> AvailableState[🟢 AVAILABLE]
        AvailableState --> RentedState[🟡 RENTED]
        AvailableState --> MaintenanceState[🟠 MAINTENANCE]
        AvailableState --> DamagedState[🔴 DAMAGED]
        RentedState --> AvailableBack[🟢 AVAILABLE]
        RentedState --> DamagedBack[🔴 DAMAGED]
        RentedState --> LostState[⚫ LOST]
        DamagedState --> MaintenanceBack[🟠 MAINTENANCE]
        DamagedState --> DisposedState[⚪ DISPOSED]
        MaintenanceState --> AvailableBack2[🟢 AVAILABLE]
        LostState --> DisposedBack[⚪ DISPOSED]
        
        H6 -.-> Users
        
        Users[("👤 USERS")]
        Venues[("🏢 VENUES")]
        BookingsTable[("📋 BOOKINGS")]
        InventoryItemsTable[("📦 INVENTORY_ITEMS")]
        InventoryImagesTable[("🖼️ INVENTORY_IMAGES")]
        InventoryTransactionsTable[("🔄 INVENTORY_TRANSACTIONS")]
        MaintenanceLogsTable[("🔧 MAINTENANCE_LOGS")]
        
        Users ~~~ Venues ~~~ BookingsTable
        InventoryItemsTable ~~~ InventoryImagesTable ~~~ InventoryTransactionsTable
        
        H7 -.-> Reports
        
        Reports --> ReportsStart[📊 REPORTS DASHBOARD]
        ReportsStart --> StockReport[📉 LOW STOCK REPORT]
        ReportsStart --> DamageReport[📊 DAMAGED ITEMS REPORT]
        ReportsStart --> RevenueReport[💰 REVENUE REPORT]
        StockReport --> AlertLow[⚠️ ALERT LOW STOCK]
        DamageReport --> ScheduleRepair[🔧 SCHEDULE REPAIRS]
        RevenueReport --> IdentifyPopular[⭐ IDENTIFY POPULAR ITEMS]
        
        H8 -.-> NotifySuccess
        
        NotifySuccess[✅ ITEM ADDED SUCCESSFULLY]
        NotifyAdminDamage[📧 ADMIN NOTIFIED OF DAMAGE]
        NotifyStaff[📱 STAFF NOTIFIED OF MAINTENANCE]
        SendConfirmation[📨 CONFIRMATION SENT]
        
        AdminPortal --> InventoryMgmt
        StaffPortal --> ProcessCheckout
        MakeBooking --> BookingsTable
        SaveItem --> InventoryItemsTable
        UploadImages --> InventoryImagesTable
        ConfirmBooking --> SendConfirmation
        SetStatusDamaged --> NotifyAdminDamage
        SetMaintenance --> NotifyStaff
        ItemSaved --> NotifySuccess
        
        BookingsTable --> InventoryTransactionsTable
        InventoryItemsTable --> InventoryTransactionsTable
        InventoryItemsTable --> MaintenanceLogsTable
        InventoryItemsTable --> InventoryImagesTable
        
        SetAvailable --> AvailableState
        SetRented --> RentedState
        SetDamaged --> DamagedState
        SetMaintenance --> MaintenanceState
        SetLost --> LostState
    end
    
    class Start,CheckRole,CustomerPortal,AdminPortal,StaffPortal,BrowseVenues,MakeBooking,BookingMgmt,Reports,ProcessCheckout,UpdateStatus default
    class AddItem,UploadImages,SaveItem,EditItem,CreateReport,ReturnItems,ProcessDamage,IssueItems,CollectItems,InspectItems,UpdateItem,DeleteItem default
    class Action,Filter,DeleteConfirm,SelectStatus,CheckAvailability,CustomerChoice,CheckItemAvailability,ItemActions default
    class InventoryMgmt,ViewItems,UpdateItemStatus,UpdateInventory,UpdateDamagedStatus,DisplayGrid default
    class ReserveItems,ConfirmBooking,SelectVenue,SelectItems,AdjustBooking,CreateTransaction,CalculateTotal,ProcessPayment default
    class Users,Venues,BookingsTable,InventoryItemsTable,InventoryImagesTable,InventoryTransactionsTable,MaintenanceLogsTable default
    class NotifySuccess,NotifyAdminDamage,NotifyStaff,SendConfirmation,AlertLow,NotifyAdmin default
    class S1,AvailableState,RentedState,MaintenanceState,DamagedState,LostState,DisposedState,AvailableBack,DamagedBack,MaintenanceBack default